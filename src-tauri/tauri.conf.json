{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Timecard Display",
  "version": "0.1.0",
  "identifier": "com.tauri.deva",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "Timecard Display",
        "width": 1280,
        "height": 800,
        "fullscreen": true,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
